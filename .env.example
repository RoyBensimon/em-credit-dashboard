# EM Credit Analytics Dashboard — Environment Variables
# Copy this file to .env and fill in your credentials.
# The app runs in full demo mode without any of these.

# ── FRED API (optional) ───────────────────────────────────────────────────────
# Free key available at: https://fred.stlouisfed.org/docs/api/api_key.html
# Used for: UST yields (DGS2, DGS5, DGS10, DGS30), SOFR, DXY (DTWEXBGS)
FRED_API_KEY=your_fred_api_key_here

# ── Data mode ──────────────────────────────────────────────────────────────────
# 'demo'     : use yfinance + synthetic bond data (default)
# 'internal' : expect uploaded CSV/Excel data via the Data Upload page
DATA_MODE=demo

# ── Bloomberg (future integration, not yet implemented) ───────────────────────
# BLOOMBERG_HOST=localhost
# BLOOMBERG_PORT=8194

# ── Internal data path (optional, for automated loading) ─────────────────────
# If set, the app will attempt to load this file on startup instead of
# using synthetic data. Must be a wide-format CSV with date index.
# INTERNAL_OAS_PATH=/path/to/internal/oas_data.csv
# INTERNAL_META_PATH=/path/to/internal/bond_metadata.csv
